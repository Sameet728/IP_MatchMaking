# ─────────────────────────────────────────────
#  IP COS Backend — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ipcos?schema=public"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# File Storage (local for dev, S3 for prod)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# AI Integration (Phase 5B)
OPENAI_API_KEY="sk-your-openai-key-here"
GEMINI_API_KEY="your-gemini-key-here"

# Email (Phase 5C)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@ipcos.in"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
