// ═══════════════════════════════════════════════════════════════
//  IP Commercialization OS — Prisma Schema
//  Full production database schema
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ─── ENUMS ──────────────────────────────────────────────────────

enum UserRole {
  INVENTOR
  UNIVERSITY
  STARTUP
  ENTERPRISE
  BROKER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum PatentStatus {
  PROVISIONAL
  FILED
  PUBLISHED
  GRANTED
  ABANDONED
  EXPIRED
  LICENSED
}

enum PatentType {
  UTILITY
  DESIGN
  PLANT
  PCT
  CONTINUATION
  DIVISIONAL
}

enum TechDomain {
  AI_ML
  BIOTECH
  CLEAN_TECH
  SEMICONDUCTOR
  HEALTHCARE
  ENERGY
  AGRICULTURE
  MANUFACTURING
  MATERIALS
  DEFENSE
  IT_SOFTWARE
  AUTOMOTIVE
  PHARMA
  NANOTECHNOLOGY
  OTHER
}

enum DealStatus {
  INQUIRY
  NDA_SENT
  NDA_SIGNED
  TERM_SHEET
  DUE_DILIGENCE
  NEGOTIATING
  AGREEMENT_DRAFT
  SIGNED
  ACTIVE
  COMPLETED
  TERMINATED
}

enum DealType {
  EXCLUSIVE_LICENSE
  NON_EXCLUSIVE_LICENSE
  CROSS_LICENSE
  ASSIGNMENT
  JOINT_VENTURE
  SPONSORED_RESEARCH
  OPTION_AGREEMENT
}

enum RoyaltyStatus {
  PENDING
  PAID
  OVERDUE
  DISPUTED
  WAIVED
}

enum MessageType {
  TEXT
  FILE
  DEAL_PROPOSAL
  NDA_REQUEST
  COUNTER_OFFER
  SYSTEM
  MILESTONE
}

enum NotificationType {
  DEAL
  PATENT
  AI
  ROYALTY
  MESSAGE
  SYSTEM
}

enum ReportType {
  AI_PORTFOLIO
  VALUATION
  COMMERCIALIZATION
  BUYER_MATCH
  DEAL_SUMMARY
  ROYALTY_COLLECTION
  PLATFORM_ANALYTICS
}

enum ReportStatus {
  GENERATING
  READY
  FAILED
  SCHEDULED
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
  JSON
}

// ─── ORGANIZATION ───────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  type        UserRole
  email       String?  @unique
  phone       String?
  website     String?
  address     String?
  city        String?
  state       String?
  country     String   @default("India")
  pincode     String?
  logo        String?  // URL

  // University-specific
  universityId  String?
  dstRating     String?
  naacGrade     String?

  // Company-specific
  cin           String?  // Company Identification Number
  gstin         String?
  industry      String?
  employeeCount Int?
  revenue       Float?   // Annual revenue in INR
  stage         String?  // Startup/SME/Large/MNC

  isVerified    Boolean  @default(false)
  verifiedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  patents   Patent[]
  deals     Deal[]    @relation("CompanyDeals")
  matchRequests MatchRequest[]
}

// ─── USER ────────────────────────────────────────────────────────

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String
  name           String
  role           UserRole
  status         UserStatus @default(PENDING_VERIFICATION)

  phone          String?
  avatar         String?
  bio            String?
  designation    String?
  linkedinUrl    String?
  googleScholar  String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // Verification
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  otpCode           String?
  otpExpiresAt      DateTime?

  // JWT refresh token
  refreshToken      String?
  refreshTokenExp   DateTime?

  lastLoginAt       DateTime?
  loginCount        Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patents          Patent[]         @relation("InventorPatents")
  sentMessages     Message[]        @relation("SentMessages")
  notifications    Notification[]
  reports          Report[]
  savedPatents     SavedPatent[]
  dealParticipants DealParticipant[]
  aiAnalysisJobs   AIAnalysisJob[]
  auditLogs        AuditLog[]

  @@index([email])
  @@index([role])
  @@index([organizationId])
}

// ─── PATENT ──────────────────────────────────────────────────────

model Patent {
  id              String       @id @default(cuid())
  title           String
  patentNumber    String?      @unique
  applicationNumber String?
  status          PatentStatus @default(FILED)
  type            PatentType   @default(UTILITY)

  // Filing details
  filingDate      DateTime?
  grantDate       DateTime?
  expiryDate      DateTime?
  publicationDate DateTime?
  country         String       @default("India")
  ipcCodes        String[]     // International Patent Classification
  cpcCodes        String[]     // Cooperative Patent Classification

  // Technical
  abstract        String       @db.Text
  description     String?      @db.Text
  claims          String?      @db.Text
  domain          TechDomain
  subDomain       String?
  keywords        String[]
  trl             Int          @default(1) // Technology Readiness Level 1-9

  // Commercial
  isListed        Boolean      @default(false)  // Listed on marketplace
  listingDate     DateTime?
  askingPrice     Float?       // Upfront licensing fee
  royaltyRate     Float?       // Royalty % requested
  licenseType     String?      // Exclusive/Non-exclusive
  isExclusive     Boolean      @default(false)

  // Ownership
  inventorId      String
  inventor        User         @relation("InventorPatents", fields: [inventorId], references: [id])
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  // Co-inventors
  coInventors     String[]     // Names (will be linked to users in v2)

  // Stats
  viewCount       Int          @default(0)
  inquiryCount    Int          @default(0)
  saveCount       Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  aiReport        AIReport?
  documents       PatentDocument[]
  deals           DealPatent[]
  saved           SavedPatent[]
  familyMembers   PatentFamily[]   @relation("PrimaryPatent")
  partOfFamilies  PatentFamily[]   @relation("FamilyMember")
  royalties       Royalty[]
  aiJobs          AIAnalysisJob[]
  matchResults    MatchResult[]

  @@index([status])
  @@index([domain])
  @@index([inventorId])
  @@index([isListed])
  @@index([patentNumber])
}

// ─── PATENT DOCUMENT ─────────────────────────────────────────────

model PatentDocument {
  id         String  @id @default(cuid())
  patentId   String
  patent     Patent  @relation(fields: [patentId], references: [id], onDelete: Cascade)
  name       String
  type       String  // pdf, image, video, etc.
  url        String
  size       Int     // bytes
  isPublic   Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([patentId])
}

// ─── PATENT FAMILY ───────────────────────────────────────────────

model PatentFamily {
  id              String  @id @default(cuid())
  primaryPatentId String
  primaryPatent   Patent  @relation("PrimaryPatent", fields: [primaryPatentId], references: [id])
  memberPatentId  String
  memberPatent    Patent  @relation("FamilyMember", fields: [memberPatentId], references: [id])
  relationship    String  // continuation, divisional, PCT, etc.

  @@unique([primaryPatentId, memberPatentId])
}

// ─── AI REPORT ───────────────────────────────────────────────────

model AIReport {
  id        String  @id @default(cuid())
  patentId  String  @unique
  patent    Patent  @relation(fields: [patentId], references: [id], onDelete: Cascade)

  // Overall scores (0-100)
  overallScore    Int
  noveltyScore    Int
  commercialScore Int
  marketFitScore  Int
  legalStrength   Int
  techReadiness   Int

  // SWOT
  strengths       String[]
  weaknesses      String[]
  opportunities   String[]
  threats         String[]

  // Market analysis
  targetMarket    String   @db.Text
  tamValue        Float?   // Total Addressable Market USD
  samValue        Float?   // Serviceable Addressable Market USD
  somValue        Float?   // Serviceable Obtainable Market USD
  marketGrowthRate Float?  // % per year

  // Revenue projections (5 years) stored as JSON
  revenueProjections Json?

  // Competitors (JSON array)
  competitors     Json?

  // Licensing recommendation
  licensingStrategy  String   @db.Text
  recommendedModel   String
  recommendedUpfront Float?
  recommendedRoyalty Float?
  minimumRoyalty     Float?

  // Risk assessment (JSON)
  risks           Json?

  // Top buyer matches (JSON array of company IDs + scores)
  topBuyers       Json?

  // Summary
  executiveSummary String  @db.Text
  aiModel          String  @default("gpt-4")
  generatedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([patentId])
}

// ─── AI ANALYSIS JOB ─────────────────────────────────────────────

model AIAnalysisJob {
  id        String  @id @default(cuid())
  patentId  String
  patent    Patent  @relation(fields: [patentId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  status    String  @default("queued") // queued, processing, completed, failed
  progress  Int     @default(0)        // 0-100
  error     String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([patentId])
  @@index([userId])
  @@index([status])
}

// ─── MATCH REQUEST ───────────────────────────────────────────────

model MatchRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // What the company is looking for
  domains        TechDomain[]
  keywords       String[]
  minTrl         Int          @default(1)
  maxBudget      Float?
  notes          String?

  results        MatchResult[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── MATCH RESULT ─────────────────────────────────────────────────

model MatchResult {
  id             String       @id @default(cuid())
  matchRequestId String?
  matchRequest   MatchRequest? @relation(fields: [matchRequestId], references: [id])
  patentId       String
  patent         Patent       @relation(fields: [patentId], references: [id])

  matchScore     Int          // 0-100
  reasons        String[]
  risks          String[]
  dealProbability Int         // 0-100
  estimatedRevenue Float?

  // Tracking
  status         String       @default("new")  // new, contacted, responded, deal_created
  contactedAt    DateTime?

  createdAt      DateTime @default(now())

  @@index([patentId])
  @@index([matchRequestId])
}

// ─── DEAL ─────────────────────────────────────────────────────────

model Deal {
  id              String     @id @default(cuid())
  title           String
  status          DealStatus @default(INQUIRY)
  type            DealType   @default(NON_EXCLUSIVE_LICENSE)

  // Financial
  upfrontFee      Float?
  royaltyRate     Float?     // %
  minimumRoyalty  Float?
  maximumLiability Float?
  duration        Int?       // years
  currency        String     @default("INR")

  // Terms
  territory       String[]   @default(["India"])
  sublicensing    Boolean    @default(false)
  sublicenseRate  Float?
  exclusiveField  String?

  // Key dates
  ndaSignedAt     DateTime?
  termSheetAt     DateTime?
  agreementAt     DateTime?
  effectiveDate   DateTime?
  expiryDate      DateTime?

  // Parties
  companyId       String
  company         Organization @relation("CompanyDeals", fields: [companyId], references: [id])

  participants    DealParticipant[]
  patents         DealPatent[]
  messages        Message[]
  milestones      DealMilestone[]
  royalties       Royalty[]

  notes           String?    @db.Text
  internalNotes   String?    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([companyId])
}

// ─── DEAL PARTICIPANT ─────────────────────────────────────────────

model DealParticipant {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])
  role   String // lead_inventor, co_inventor, broker, legal_counsel, etc.

  @@unique([dealId, userId])
  @@index([dealId])
  @@index([userId])
}

// ─── DEAL PATENT ──────────────────────────────────────────────────

model DealPatent {
  id       String @id @default(cuid())
  dealId   String
  deal     Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  patentId String
  patent   Patent @relation(fields: [patentId], references: [id])

  @@unique([dealId, patentId])
}

// ─── DEAL MILESTONE ───────────────────────────────────────────────

model DealMilestone {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String
  amount      Float?
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?

  createdAt DateTime @default(now())

  @@index([dealId])
}

// ─── MESSAGE ──────────────────────────────────────────────────────

model Message {
  id       String      @id @default(cuid())
  dealId   String
  deal     Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  senderId String
  sender   User        @relation("SentMessages", fields: [senderId], references: [id])
  type     MessageType @default(TEXT)

  content  String?  @db.Text

  // File attachment
  fileName  String?
  fileUrl   String?
  fileSize  Int?
  fileType  String?

  // Deal proposal payload (JSON)
  proposal  Json?

  readBy    String[]  // Array of user IDs who have read this message
  isEdited  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([senderId])
  @@index([createdAt])
}

// ─── ROYALTY ──────────────────────────────────────────────────────

model Royalty {
  id           String        @id @default(cuid())
  dealId       String
  deal         Deal          @relation(fields: [dealId], references: [id])
  patentId     String?
  patent       Patent?       @relation(fields: [patentId], references: [id])

  amount       Float
  currency     String        @default("INR")
  period       String        // e.g. "Q2 2024"
  dueDate      DateTime
  paidAt       DateTime?
  status       RoyaltyStatus @default(PENDING)

  paymentRef   String?       // Bank reference
  invoiceUrl   String?

  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([status])
  @@index([dueDate])
}

// ─── SAVED PATENT ─────────────────────────────────────────────────

model SavedPatent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patentId  String
  patent    Patent   @relation(fields: [patentId], references: [id], onDelete: Cascade)
  notes     String?
  savedAt   DateTime @default(now())

  @@unique([userId, patentId])
  @@index([userId])
}

// ─── NOTIFICATION ─────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ─── REPORT ───────────────────────────────────────────────────────

model Report {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  type      ReportType
  name      String
  status    ReportStatus @default(GENERATING)
  format    ReportFormat @default(PDF)
  period    String?
  fileUrl   String?
  fileSize  Int?
  pageCount Int?
  isStarred Boolean      @default(false)
  params    Json?        // Report parameters

  generatedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([type])
  @@index([status])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. LOGIN, CREATE_PATENT, UPDATE_DEAL
  entity     String?  // e.g. Patent, Deal
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── SUBSCRIPTION PLAN ────────────────────────────────────────────

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   // Free, Starter, Professional, Enterprise
  description String?
  price       Float    // Monthly price INR
  yearlyPrice Float?
  features    String[]
  maxPatents  Int?     // null = unlimited
  maxDeals    Int?
  maxUsers    Int?
  aiCredits   Int?     // AI analysis credits per month
  isActive    Boolean  @default(true)

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── SUBSCRIPTION ─────────────────────────────────────────────────

model Subscription {
  id             String           @id @default(cuid())
  organizationId String           @unique
  planId         String
  plan           SubscriptionPlan @relation(fields: [planId], references: [id])

  status         String   // active, past_due, cancelled, trialing
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
