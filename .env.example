# ==============================================================================
# IP Commercialization OS - Root Environment Variables (Docker Template)
# Copy this file to .env in the root directory before running docker-compose
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configuration (PostgreSQL Container)
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ipcos
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# 2. Backend Service Configuration
# ------------------------------------------------------------------------------
BACKEND_PORT=4000
NODE_ENV=development

# Database connection URL for backend container (points to 'db' container instead of 'localhost')
DATABASE_URL=postgresql://postgres:password@db:5432/ipcos?schema=public

# JWT Authentication Secrets (Change these in production to secure strings!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Storage Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Rate Limiting Configurations
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ------------------------------------------------------------------------------
# 3. Frontend Service Configuration
# ------------------------------------------------------------------------------
FRONTEND_PORT=5173
# This is the URL of the backend API as accessed from the user's browser (host machine)
VITE_API_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# 4. Third-Party Integrations (Optional / Fill in your own keys)
# ------------------------------------------------------------------------------
# AI Integration
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Email Integration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@ipcos.in
